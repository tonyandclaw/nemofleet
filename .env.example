# nemofleet runtime config — copy to `.env` (git-ignored) and adjust per host.
# Everything here has a sane default in lib/common.sh; override only what differs.

# Node bin dir that holds the `nemoclaw` + `openshell` CLIs.
# Leave blank to auto-detect the newest ~/.nvm/versions/node/*/bin.
NEMOFLEET_NODE_BIN=

# ── ports / endpoints ────────────────────────────────────────────────────────
HERMES_API_PORT=8642            # Hermes OpenAI-compatible API (host)
DASH_PORT=8899                  # status dashboard (host)
BRIDGE_PORT=9099                # in-sandbox cross-agent fix endpoint
NEMOCLAW_GATEWAY_PORT=18080     # nemoclaw inference gateway (NOT 8080 — Token_Hunter)
OPENCLAW_UI_PORT=18789          # my-assistant control UI
OPENCLAW2_UI_PORT=18790         # openclaw-2 control UI

# ── sandbox container name fragments (match `docker ps` → openshell-<frag>-<id>) ─
HERMES_CT_NAME=hermes-demo
OPENCLAW_CT_NAME=my-assistant
OPENCLAW2_CT_NAME=openclaw-2

# ── secrets (prefer onboarding them into the sandbox; here only if a script needs it) ─
# TELEGRAM_BOT_TOKEN=
