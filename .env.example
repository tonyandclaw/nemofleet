# nemofleet runtime config — copy to `.env` (git-ignored) and adjust per host.
# Everything here has a sane default in lib/common.sh; override only what differs.

# Node bin dir that holds the `nemoclaw` + `openshell` CLIs.
# Leave blank to auto-detect the newest ~/.nvm/versions/node/*/bin.
NEMOFLEET_NODE_BIN=

# ── ports / endpoints ────────────────────────────────────────────────────────
HERMES_API_PORT=8642            # team-lead OpenAI-compatible API (host)
DASH_PORT=8899                  # status dashboard (host)
# Set to 1 ONLY if the dashboard sits behind a trusted reverse proxy: makes it honor
# X-Forwarded-For for IP-whitelist / login-lockout decisions (spoofable when direct).
DASH_TRUST_XFF=
BRIDGE_PORT=9099                # in-worker IT-ops endpoint (team-lead delegates here)
NEMOCLAW_GATEWAY_PORT=18080     # nemoclaw inference gateway (NOT 8080 — Token_Hunter)
WORKERA_UI_PORT=18789           # worker-a control UI
WORKERB_UI_PORT=18790           # worker-b control UI

# ── sandbox container name fragments (match `docker ps` → openshell-<frag>-<id>) ─
# All three run the Hermes harness; they differ only by role/config.
TEAMLEAD_CT_NAME=team-lead       # human-facing coordinator
WORKERA_CT_NAME=worker-a         # ops worker: monitor / drift / cert
WORKERB_CT_NAME=worker-b         # security worker: CVE / SBOM / SAST / syslog

# ── inference (all nodes: Hermes harness on local NVIDIA NIM / nemotron) ──────
# The live provider is set into each sandbox with:
#   nemoclaw inference set --provider nim --model "$INFER_MODEL"
# These vars document + drive scripts and the switch runbook.
INFER_PROVIDER=nim
INFER_MODEL=nvidia/nemotron-3-super-120b-a12b
INFER_ENDPOINT=http://127.0.0.1:8000/v1   # local NIM OpenAI-compatible endpoint (adjust port/model)

# ── real device (ASUS ExpertWiFi EBG19P) ─────────────────────────────────────
# Credentials live in a git-ignored file, format: IP|USER|PASS, chmod 600.
EBG19P_CRED=~/.config/nemoclaw/ebg19p.cred

# ── real SMTP relay + Telegram + team-lead mailbox (outbound notifications) ──
# Like EBG19P_CRED above, these are real secrets — recommended home is OUTSIDE
# this repo entirely (not even this git-ignored .env), so a repo copy/backup/
# reclone never carries them: put the keys below into
#   ~/.config/nemoclaw/nemofleet-notify.env   (chmod 600)
# lib/common.sh sources it automatically (last, so it overrides anything set
# here) on every boot — no separate "link" step needed. Leaving them here in
# .env instead also works, just less isolated.
SMTP_HOST=                       # e.g. smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=                       # e.g. nemofleet@yourdomain
SMTP_STARTTLS=1
TEAMLEAD_EMAIL=                  # team-lead mailbox (its email adapter polls this)

# ── real Jira (escalations) ──────────────────────────────────────────────────
JIRA_URL=                        # e.g. https://yourorg.atlassian.net
JIRA_USER=                       # Jira account email
JIRA_TOKEN=                      # Jira API token
JIRA_PROJECT=NETOPS              # project key for opened tickets

# ── Telegram (personal chat id — never committed) ────────────────────────────
# Also belongs in ~/.config/nemoclaw/nemofleet-notify.env, see note above.
TELEGRAM_CHAT_ID=                # ask @userinfobot for yours
# TELEGRAM_BOT_TOKEN=          # set to enable the deterministic safety-net Telegram (Bot API direct)
